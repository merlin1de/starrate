# ──────────────────────────────────────────────────────────────────────────────
# StarRate Cypress E2E – Umgebungsvariablen
#
# Kopiere diese Datei nach docker/cypress.env und trage die echten Werte ein.
# cypress.env wird NICHT in Git eingecheckt (siehe .gitignore)!
# ──────────────────────────────────────────────────────────────────────────────

# Nextcloud-URL (ohne abschließenden Slash)
NC_URL=https://cloud.mischler.info

# Testbenutzer (kein Admin nötig – normaler NC-Account reicht)
# Braucht: Zugriff auf StarRate-App + Dateien in /Fotos/E2E-Test
NC_USER=test
NC_PASS=test

# Zweiter Testbenutzer für Multi-User-Tests
# Braucht: Zugriff auf /Fotos/Shared (geteilter Ordner)
NC_USER_B=test2
NC_PASS_B=test2
