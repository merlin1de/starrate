{
    "name": "starrate/starrate",
    "description": "Professionelles Foto-Bewertungs- und Lightroom-Sync-Tool für Nextcloud",
    "type": "nextcloud-app",
    "license": "AGPL-3.0-or-later",
    "authors": [
        {
            "name": "StarRate Team",
            "email": "info@starrate.app"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "nextcloud/ocp": "^31.0"
    },
    "autoload": {
        "psr-4": {
            "OCA\\StarRate\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OCA\\StarRate\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml",
        "test-unit": "phpunit --configuration phpunit.xml --testsuite unit"
    }
}
